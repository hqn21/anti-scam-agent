{
  "manifest_version": 3,
  "name": "Anti-Scam Agent",
  "version": "0.1.0",
  "description": "Right-click any link to check whether it is a scam site (via a local Anti-Scam Agent).",
  "permissions": ["contextMenus", "storage", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "css": ["content.css"], "run_at": "document_idle" }
  ],
  "options_page": "options.html"
}
