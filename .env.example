OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# AgentMail (required). The persona's email is routed through one of these inboxes so the
# Browsing Agent can read verification codes mid-flow; the app fails fast if this is unset.
AGENTMAIL_API_KEY=
# Comma-separated inboxes to rotate through (defaults to the three below if unset).
AGENTMAIL_INBOXES=asalpha@agentmail.to,asbravo@agentmail.to,ascharlie@agentmail.to
